<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.RadioButton?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="org.example.project_3.Controller">

    <center>
        <TabPane fx:id="mainTabPane" tabClosingPolicy="UNAVAILABLE">
            <tabs>

                <!-- ADD / REMOVE STUDENT TAB -->
                <Tab text="Students">
                    <content>
                        <VBox spacing="15" padding="15">
                            <GridPane hgap="10" vgap="10">
                                <Label text="First Name:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                                <TextField fx:id="firstNameField" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                                <Label text="Last Name:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                                <TextField fx:id="lastNameField" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                                <Label text="Date of Birth:" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                                <TextField fx:id="dobField" promptText="mm/dd/yyyy"
                                           GridPane.rowIndex="2" GridPane.columnIndex="1"/>

                                <Label text="Major:" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
                                <ComboBox fx:id="majorBox" prefWidth="180"
                                          GridPane.rowIndex="3" GridPane.columnIndex="1"/>

                                <Label text="Credits Completed:" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
                                <TextField fx:id="creditsField" GridPane.rowIndex="4" GridPane.columnIndex="1"/>
                            </GridPane>

                            <VBox spacing="8">
                                <Label text="Student Type:"/>
                                <HBox spacing="12">
                                    <RadioButton fx:id="residentRadio"
                                                 text="Resident"
                                                 onAction="#updateExtraFields"/>
                                    <RadioButton fx:id="nonResidentRadio"
                                                 text="Non-Resident"
                                                 onAction="#updateExtraFields"/>
                                    <RadioButton fx:id="triStateRadio"
                                                 text="Tri-State"
                                                 onAction="#updateExtraFields"/>
                                    <RadioButton fx:id="internationalRadio"
                                                 text="International"
                                                 onAction="#updateExtraFields"/>
                                </HBox>
                            </VBox>

                            <HBox spacing="15">
                                <VBox spacing="5">
                                    <Label text="State (Tri-State only):"/>
                                    <ComboBox fx:id="stateBox" prefWidth="120"/>
                                </VBox>

                                <VBox spacing="5">
                                    <Label text="International Option:"/>
                                    <CheckBox fx:id="studyAbroadCheckBox" text="Study Abroad"/>
                                </VBox>
                            </HBox>

                            <HBox spacing="10">
                                <Button text="Add Student" onAction="#handleAddStudent"/>
                                <Button text="Remove Student" onAction="#handleRemove"/>
                                <Button text="Clear Fields" onAction="#handleClearFields"/>
                            </HBox>
                        </VBox>
                    </content>
                </Tab>

                <!-- OPEN / CLOSE SECTION TAB -->
                <Tab text="Sections">
                    <content>
                        <VBox spacing="15" padding="15">
                            <GridPane hgap="10" vgap="10">
                                <Label text="Course:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                                <ComboBox fx:id="courseBox" prefWidth="180"
                                          GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                                <Label text="Period:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                                <ComboBox fx:id="periodBox" prefWidth="180"
                                          GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                                <Label text="Instructor:" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                                <ComboBox fx:id="instructorBox" prefWidth="180"
                                          GridPane.rowIndex="2" GridPane.columnIndex="1"/>

                                <Label text="Classroom:" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
                                <ComboBox fx:id="classroomBox" prefWidth="180"
                                          GridPane.rowIndex="3" GridPane.columnIndex="1"/>

                                <Label text="Time:" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
                                <TextField fx:id="timeField" editable="false"
                                           GridPane.rowIndex="4" GridPane.columnIndex="1"/>
                            </GridPane>

                            <HBox spacing="10">
                                <Button text="Open Section" onAction="#handleOpenSection"/>
                                <Button text="Close Section" onAction="#handleCloseSectionButton"/>
                            </HBox>
                        </VBox>
                    </content>
                </Tab>

                <!-- ENROLL TAB -->
                <Tab text="Enroll">
                    <content>
                        <VBox spacing="15" padding="15">
                            <GridPane hgap="10" vgap="10">
                                <Label text="First Name:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                                <TextField fx:id="firstNameFieldEnrollDummy" visible="false" managed="false"/>
                                <TextField fx:id="firstNameField" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                                <Label text="Last Name:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                                <TextField fx:id="lastNameField" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                                <Label text="Date of Birth:" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                                <TextField fx:id="dobField" promptText="mm/dd/yyyy"
                                           GridPane.rowIndex="2" GridPane.columnIndex="1"/>

                                <Label text="Course:" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
                                <ComboBox fx:id="courseBox" prefWidth="180"
                                          GridPane.rowIndex="3" GridPane.columnIndex="1"/>

                                <Label text="Period:" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
                                <ComboBox fx:id="periodBox" prefWidth="180"
                                          GridPane.rowIndex="4" GridPane.columnIndex="1"/>
                            </GridPane>

                            <Button text="Enroll" onAction="#handleEnroll"/>
                        </VBox>
                    </content>
                </Tab>

                <!-- DROP TAB -->
                <Tab text="Drop">
                    <content>
                        <VBox spacing="15" padding="15">
                            <GridPane hgap="10" vgap="10">
                                <Label text="First Name:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                                <TextField fx:id="dropFirstNameField" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                                <Label text="Last Name:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                                <TextField fx:id="dropLastNameField" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                                <Label text="Date of Birth:" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                                <TextField fx:id="dropDobField" promptText="mm/dd/yyyy"
                                           GridPane.rowIndex="2" GridPane.columnIndex="1"/>

                                <Label text="Course:" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
                                <ComboBox fx:id="dropCourseBox" prefWidth="180"
                                          GridPane.rowIndex="3" GridPane.columnIndex="1"/>

                                <Label text="Period:" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
                                <ComboBox fx:id="dropTimeBox" prefWidth="180"
                                          GridPane.rowIndex="4" GridPane.columnIndex="1"/>
                            </GridPane>

                            <Button text="Drop" onAction="#handleDrop"/>
                        </VBox>
                    </content>
                </Tab>

            </tabs>
        </TabPane>
    </center>

    <bottom>
        <TextArea fx:id="outputArea"
                  editable="false"
                  prefRowCount="10"
                  wrapText="true"
                  BorderPane.alignment="CENTER"/>
    </bottom>

</BorderPane>