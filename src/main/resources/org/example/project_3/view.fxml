<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.RadioButton?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<TabPane fx:id="mainTabPane"
         xmlns="http://javafx.com/javafx/21"
         xmlns:fx="http://javafx.com/fxml/1"
         fx:controller="org.example.project_3.Controller">

    <tabs>
        <Tab text="Students" closable="false">
            <VBox spacing="15">
                <padding>
                    <Insets top="15" right="15" bottom="15" left="15"/>
                </padding>

                <children>
                    <Label text="Student Information" style="-fx-font-size: 16px; -fx-font-weight: bold;"/>

                    <GridPane hgap="10" vgap="10">
                        <children>
                            <Label text="First Name:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                            <TextField fx:id="firstNameField"
                                       promptText="First name"
                                       GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                            <Label text="Last Name:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                            <TextField fx:id="lastNameField"
                                       promptText="Last name"
                                       GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                            <Label text="Date of Birth:" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                            <TextField fx:id="dobField"
                                       promptText="MM/DD/YYYY"
                                       GridPane.rowIndex="2" GridPane.columnIndex="1"/>

                            <Label text="Major:" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
                            <ComboBox fx:id="majorBox"
                                      prefWidth="180"
                                      GridPane.rowIndex="3" GridPane.columnIndex="1"/>

                            <Label text="Credits Completed:" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
                            <TextField fx:id="creditsField"
                                       promptText="Credits"
                                       GridPane.rowIndex="4" GridPane.columnIndex="1"/>
                        </children>
                    </GridPane>

                    <Separator/>

                    <Label text="Student Type" style="-fx-font-size: 14px; -fx-font-weight: bold;"/>

                    <VBox spacing="8">
                        <children>
                            <RadioButton fx:id="residentRadio"
                                         text="Resident"
                                         onAction="#updateExtraFields"/>
                            <RadioButton fx:id="nonResidentRadio"
                                         text="Non-Resident"
                                         onAction="#updateExtraFields"/>
                            <RadioButton fx:id="triStateRadio"
                                         text="Tri-State"
                                         onAction="#updateExtraFields"/>
                            <RadioButton fx:id="internationalRadio"
                                         text="International"
                                         onAction="#updateExtraFields"/>
                        </children>
                    </VBox>

                    <GridPane hgap="10" vgap="10">
                        <children>
                            <Label text="State:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                            <ComboBox fx:id="stateBox"
                                      prefWidth="120"
                                      GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                            <Label text="Study Abroad:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                            <CheckBox fx:id="studyAbroadCheckBox"
                                      GridPane.rowIndex="1" GridPane.columnIndex="1"/>
                        </children>
                    </GridPane>

                    <HBox spacing="10">
                        <children>
                            <Button text="Add Student" onAction="#handleAddStudent"/>
                            <Button text="Remove Student" onAction="#handleRemove"/>
                            <Button text="Clear Fields" onAction="#handleClearFields"/>
                        </children>
                    </HBox>
                </children>
            </VBox>
        </Tab>

        <Tab text="Sections / Enrollment" closable="false">
            <VBox spacing="15">
                <padding>
                    <Insets top="15" right="15" bottom="15" left="15"/>
                </padding>

                <children>
                    <Label text="Section Information" style="-fx-font-size: 16px; -fx-font-weight: bold;"/>

                    <GridPane hgap="10" vgap="10">
                        <children>
                            <Label text="Course:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                            <TextField fx:id="courseField"
                                       promptText="e.g. CS111"
                                       GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                            <Label text="Period (Open):" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                            <TextField fx:id="periodField"
                                       promptText="1-6"
                                       GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                            <Label text="Instructor:" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                            <TextField fx:id="instructorField"
                                       promptText="e.g. PATEL"
                                       GridPane.rowIndex="2" GridPane.columnIndex="1"/>

                            <Label text="Classroom:" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
                            <TextField fx:id="classroomField"
                                       promptText="e.g. HIL114"
                                       GridPane.rowIndex="3" GridPane.columnIndex="1"/>

                            <Label text="Time / Period (Close/Enroll):" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
                            <TextField fx:id="timeField"
                                       promptText="1-6"
                                       GridPane.rowIndex="4" GridPane.columnIndex="1"/>
                        </children>
                    </GridPane>

                    <HBox spacing="10">
                        <children>
                            <Button text="Open Section" onAction="#handleOpenSection"/>
                            <Button text="Close Section" onAction="#handleCloseSectionButton"/>
                            <Button text="Enroll Student" onAction="#handleEnroll"/>
                        </children>
                    </HBox>
                </children>
            </VBox>
        </Tab>

        <Tab text="Output" closable="false">
            <VBox spacing="10">
                <padding>
                    <Insets top="15" right="15" bottom="15" left="15"/>
                </padding>

                <children>
                    <Label text="Output" style="-fx-font-size: 16px; -fx-font-weight: bold;"/>
                    <TextArea fx:id="outputArea"
                              editable="false"
                              wrapText="true"
                              prefHeight="450"/>
                </children>
            </VBox>
        </Tab>
    </tabs>
</TabPane>