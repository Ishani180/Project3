<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/8"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="org.example.project_3.Controller">

    <center>
        <TabPane fx:id="mainTabPane" tabClosingPolicy="UNAVAILABLE">
            <tabs>

                <!-- ADD / REMOVE STUDENT -->
                <Tab text="Add/Remove Student">
                    <content>
                        <VBox spacing="15">
                            <padding>
                                <Insets top="15" right="15" bottom="15" left="15"/>
                            </padding>

                            <GridPane hgap="12" vgap="12">
                                <Label text="First Name:" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                                <TextField fx:id="firstNameField" GridPane.columnIndex="1" GridPane.rowIndex="0"/>

                                <Label text="Last Name:" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                                <TextField fx:id="lastNameField" GridPane.columnIndex="1" GridPane.rowIndex="1"/>

                                <Label text="Date of Birth:" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                                <TextField fx:id="dobField" promptText="mm/dd/yyyy"
                                           GridPane.columnIndex="1" GridPane.rowIndex="2"/>

                                <Label text="Major:" GridPane.columnIndex="0" GridPane.rowIndex="3"/>
                                <ComboBox fx:id="majorBox" prefWidth="220"
                                          GridPane.columnIndex="1" GridPane.rowIndex="3"/>

                                <Label text="Credits Completed:" GridPane.columnIndex="0" GridPane.rowIndex="4"/>
                                <TextField fx:id="creditsField" GridPane.columnIndex="1" GridPane.rowIndex="4"/>
                            </GridPane>

                            <VBox spacing="8">
                                <Label text="Student Type:"/>
                                <HBox spacing="12">
                                    <RadioButton fx:id="residentRadio" text="Resident" onAction="#updateExtraFields"/>
                                    <RadioButton fx:id="nonResidentRadio" text="Non-Resident" onAction="#updateExtraFields"/>
                                    <RadioButton fx:id="triStateRadio" text="Tri-State" onAction="#updateExtraFields"/>
                                    <RadioButton fx:id="internationalRadio" text="International" onAction="#updateExtraFields"/>
                                </HBox>
                            </VBox>

                            <HBox spacing="20">
                                <VBox spacing="6">
                                    <Label text="State:"/>
                                    <ComboBox fx:id="stateBox" prefWidth="120"/>
                                </VBox>

                                <VBox spacing="6">
                                    <Label text="Study Abroad:"/>
                                    <CheckBox fx:id="studyAbroadCheckBox" text="Yes"/>
                                </VBox>
                            </HBox>

                            <HBox spacing="10">
                                <Button text="Add Student" onAction="#handleAddStudent"/>
                                <Button text="Remove Student" onAction="#handleRemove"/>
                                <Button text="Clear Fields" onAction="#handleClearFields"/>
                            </HBox>
                        </VBox>
                    </content>
                </Tab>

                <!-- OPEN / CLOSE SECTION -->
                <Tab text="Open/Close Section">
                    <content>
                        <VBox spacing="15">
                            <padding>
                                <Insets top="15" right="15" bottom="15" left="15"/>
                            </padding>

                            <GridPane hgap="12" vgap="12">
                                <Label text="Course:" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                                <ComboBox fx:id="courseBox" prefWidth="220"
                                          GridPane.columnIndex="1" GridPane.rowIndex="0"/>

                                <Label text="Period:" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                                <ComboBox fx:id="periodBox" prefWidth="220"
                                          GridPane.columnIndex="1" GridPane.rowIndex="1"/>

                                <Label text="Instructor:" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                                <ComboBox fx:id="instructorBox" prefWidth="220"
                                          GridPane.columnIndex="1" GridPane.rowIndex="2"/>

                                <Label text="Classroom:" GridPane.columnIndex="0" GridPane.rowIndex="3"/>
                                <ComboBox fx:id="classroomBox" prefWidth="220"
                                          GridPane.columnIndex="1" GridPane.rowIndex="3"/>

                                <Label text="Time:" GridPane.columnIndex="0" GridPane.rowIndex="4"/>
                                <TextField fx:id="timeField" editable="false"
                                           GridPane.columnIndex="1" GridPane.rowIndex="4"/>
                            </GridPane>

                            <HBox spacing="10">
                                <Button text="Open Section" onAction="#handleOpenSection"/>
                                <Button text="Close Section" onAction="#handleCloseSectionButton"/>
                            </HBox>
                        </VBox>
                    </content>
                </Tab>

                <!-- ENROLL / DROP -->
                <Tab text="Enroll/Drop">
                    <content>
                        <VBox spacing="20">
                            <padding>
                                <Insets top="15" right="15" bottom="15" left="15"/>
                            </padding>

                            <HBox spacing="20">
                                <VBox spacing="10" HBox.hgrow="ALWAYS">
                                    <Label text="Enroll Student List"/>
                                    <HBox spacing="10">
                                        <ComboBox fx:id="enrollStudentBox" prefWidth="220"/>
                                        <Button text="Load Students" onAction="#handleLoad"/>
                                    </HBox>
                                </VBox>

                                <VBox spacing="10" HBox.hgrow="ALWAYS">
                                    <Label text="Drop Student List"/>
                                    <HBox spacing="10">
                                        <ComboBox fx:id="dropStudentBox" prefWidth="220"/>
                                        <Button text="Load Students" onAction="#handleLoad"/>
                                    </HBox>
                                </VBox>
                            </HBox>

                            <Separator/>

                            <HBox spacing="30">
                                <!-- ENROLL SIDE -->
                                <VBox spacing="12" HBox.hgrow="ALWAYS">
                                    <Label text="Enroll" style="-fx-font-size: 14px; -fx-font-weight: bold;"/>

                                    <GridPane hgap="12" vgap="12">
                                        <Label text="First Name:" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                                        <TextField fx:id="enrollFirstNameField"
                                                   GridPane.columnIndex="1" GridPane.rowIndex="0"/>

                                        <Label text="Last Name:" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                                        <TextField fx:id="enrollLastNameField"
                                                   GridPane.columnIndex="1" GridPane.rowIndex="1"/>

                                        <Label text="Date of Birth:" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                                        <TextField fx:id="enrollDobField" promptText="mm/dd/yyyy"
                                                   GridPane.columnIndex="1" GridPane.rowIndex="2"/>

                                        <Label text="Course:" GridPane.columnIndex="0" GridPane.rowIndex="3"/>
                                        <ComboBox fx:id="enrollCourseBox" prefWidth="180"
                                                  GridPane.columnIndex="1" GridPane.rowIndex="3"/>

                                        <Label text="Period:" GridPane.columnIndex="0" GridPane.rowIndex="4"/>
                                        <ComboBox fx:id="enrollPeriodBox" prefWidth="180"
                                                  GridPane.columnIndex="1" GridPane.rowIndex="4"/>
                                    </GridPane>

                                    <Button text="Enroll" prefWidth="180" onAction="#handleEnroll"/>
                                </VBox>

                                <!-- DROP SIDE -->
                                <VBox spacing="12" HBox.hgrow="ALWAYS">
                                    <Label text="Drop" style="-fx-font-size: 14px; -fx-font-weight: bold;"/>

                                    <GridPane hgap="12" vgap="12">
                                        <Label text="First Name:" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                                        <TextField fx:id="dropFirstNameField"
                                                   GridPane.columnIndex="1" GridPane.rowIndex="0"/>

                                        <Label text="Last Name:" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                                        <TextField fx:id="dropLastNameField"
                                                   GridPane.columnIndex="1" GridPane.rowIndex="1"/>

                                        <Label text="Date of Birth:" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                                        <TextField fx:id="dropDobField" promptText="mm/dd/yyyy"
                                                   GridPane.columnIndex="1" GridPane.rowIndex="2"/>

                                        <Label text="Course:" GridPane.columnIndex="0" GridPane.rowIndex="3"/>
                                        <ComboBox fx:id="dropCourseBox" prefWidth="180"
                                                  GridPane.columnIndex="1" GridPane.rowIndex="3"/>

                                        <Label text="Period:" GridPane.columnIndex="0" GridPane.rowIndex="4"/>
                                        <ComboBox fx:id="dropTimeBox" prefWidth="180"
                                                  GridPane.columnIndex="1" GridPane.rowIndex="4"/>
                                    </GridPane>

                                    <Button text="Drop" prefWidth="180" onAction="#handleDrop"/>
                                </VBox>
                            </HBox>
                        </VBox>
                    </content>
                </Tab>
                <Tab text="Enroll/Drop">
                    ...
                </Tab>

                <Tab text="Scholarship">
                    <content>
                        <AnchorPane>
                            <children>

                                <Label layoutX="45.0" layoutY="55.0" text="First Name" />
                                <TextField fx:id="scholarshipFirstNameField"
                                           layoutX="150.0" layoutY="48.0"
                                           prefWidth="480.0" />

                                <Label layoutX="45.0" layoutY="115.0" text="Last Name" />
                                <TextField fx:id="scholarshipLastNameField"
                                           layoutX="150.0" layoutY="108.0"
                                           prefWidth="480.0" />

                                <Label layoutX="45.0" layoutY="175.0" text="Date of Birth" />
                                <TextField fx:id="scholarshipDobField"
                                           layoutX="150.0" layoutY="168.0"
                                           prefWidth="480.0"
                                           promptText="mm/dd/yyyy" />

                                <Label layoutX="45.0" layoutY="235.0" text="Amount" />
                                <TextField fx:id="scholarshipField"
                                           layoutX="150.0" layoutY="228.0"
                                           prefWidth="480.0" />

                                <Button text="Update Scholarship Amount"
                                        layoutX="150.0" layoutY="295.0"
                                        prefWidth="210.0"
                                        onAction="#handleScholarshipFX"/>

                            </children>
                        </AnchorPane>
                    </content>
                </Tab>
            </tabs>
        </TabPane>
    </center>
    <bottom>
        <TextArea fx:id="outputArea"
                  editable="false"
                  wrapText="true"
                  prefRowCount="10"/>
    </bottom>
</BorderPane>

