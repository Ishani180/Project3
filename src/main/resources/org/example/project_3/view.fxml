<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.RadioButton?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="org.example.project_3.Controller"
      spacing="12">

    <padding>
        <Insets top="12" right="12" bottom="12" left="12"/>
    </padding>

    <TabPane fx:id="mainTabPane" tabClosingPolicy="UNAVAILABLE">

        <tabs>

            <!-- ADD / REMOVE STUDENT -->
            <Tab text="Students">
                <content>
                    <VBox spacing="12">
                        <padding>
                            <Insets top="12" right="12" bottom="12" left="12"/>
                        </padding>

                        <Label text="Add / Remove Student"
                               style="-fx-font-size: 16px; -fx-font-weight: bold;"/>

                        <HBox spacing="10">
                            <VBox spacing="4">
                                <Label text="First Name"/>
                                <TextField fx:id="firstNameField" promptText="First name"/>
                            </VBox>
                            <VBox spacing="4">
                                <Label text="Last Name"/>
                                <TextField fx:id="lastNameField" promptText="Last name"/>
                            </VBox>
                            <VBox spacing="4">
                                <Label text="Date of Birth"/>
                                <TextField fx:id="dobField" promptText="mm/dd/yyyy"/>
                            </VBox>
                        </HBox>

                        <HBox spacing="10">
                            <VBox spacing="4">
                                <Label text="Major"/>
                                <ComboBox fx:id="majorBox" prefWidth="150"/>
                            </VBox>
                            <VBox spacing="4">
                                <Label text="Credits Completed"/>
                                <TextField fx:id="creditsField" promptText="Credits"/>
                            </VBox>
                        </HBox>

                        <Label text="Student Type"/>

                        <HBox spacing="14">
                            <RadioButton fx:id="residentRadio"
                                         text="Resident"
                                         onAction="#updateExtraFields"/>
                            <RadioButton fx:id="nonResidentRadio"
                                         text="Non-Resident"
                                         onAction="#updateExtraFields"/>
                            <RadioButton fx:id="triStateRadio"
                                         text="Tri-State"
                                         onAction="#updateExtraFields"/>
                            <RadioButton fx:id="internationalRadio"
                                         text="International"
                                         onAction="#updateExtraFields"/>
                        </HBox>

                        <HBox spacing="10">
                            <VBox spacing="4">
                                <Label text="State"/>
                                <ComboBox fx:id="stateBox" prefWidth="120"/>
                            </VBox>
                            <VBox spacing="4">
                                <Label text="Options"/>
                                <CheckBox fx:id="studyAbroadCheckBox" text="Study Abroad"/>
                            </VBox>
                        </HBox>

                        <HBox spacing="10">
                            <Button text="Add Student" onAction="#handleAddStudent"/>
                            <Button text="Remove Student" onAction="#handleRemove"/>
                            <Button text="Clear Fields" onAction="#handleClearFields"/>
                            <Button text="Load Students" onAction="#handleLoad"/>
                        </HBox>
                    </VBox>
                </content>
            </Tab>

            <!-- OPEN / CLOSE SECTION -->
            <Tab text="Sections">
                <content>
                    <VBox spacing="12">
                        <padding>
                            <Insets top="12" right="12" bottom="12" left="12"/>
                        </padding>

                        <Label text="Open / Close Section"
                               style="-fx-font-size: 16px; -fx-font-weight: bold;"/>

                        <HBox spacing="10">
                            <VBox spacing="4">
                                <Label text="Course"/>
                                <ComboBox fx:id="courseBox" prefWidth="150"/>
                            </VBox>
                            <VBox spacing="4">
                                <Label text="Period"/>
                                <ComboBox fx:id="periodBox" prefWidth="150"/>
                            </VBox>
                        </HBox>

                        <HBox spacing="10">
                            <VBox spacing="4">
                                <Label text="Instructor"/>
                                <ComboBox fx:id="instructorBox" prefWidth="150"/>
                            </VBox>
                            <VBox spacing="4">
                                <Label text="Classroom"/>
                                <ComboBox fx:id="classroomBox" prefWidth="150"/>
                            </VBox>
                        </HBox>

                        <HBox spacing="10">
                            <Button text="Open Section" onAction="#handleOpenSection"/>
                            <Button text="Close Section" onAction="#handleCloseSectionButton"/>
                        </HBox>
                    </VBox>
                </content>
            </Tab>

            <!-- ENROLL / DROP -->
            <Tab text="Enroll / Drop">
                <content>
                    <VBox spacing="12">
                        <padding>
                            <Insets top="12" right="12" bottom="12" left="12"/>
                        </padding>

                        <Label text="Enroll / Drop Students"
                               style="-fx-font-size: 16px; -fx-font-weight: bold;"/>

                        <VBox spacing="4">
                            <Label text="Student List"/>
                            <ComboBox fx:id="studentListBox" prefWidth="320" promptText="StudentList"/>
                        </VBox>

                        <Separator/>

                        <Label text="Enroll Student" style="-fx-font-weight: bold;"/>

                        <HBox spacing="10">
                            <VBox spacing="4">
                                <Label text="First Name"/>
                                <TextField fx:id="enrollFirstNameField" promptText="First name"/>
                            </VBox>
                            <VBox spacing="4">
                                <Label text="Last Name"/>
                                <TextField fx:id="enrollLastNameField" promptText="Last name"/>
                            </VBox>
                            <VBox spacing="4">
                                <Label text="Date of Birth"/>
                                <TextField fx:id="enrollDobField" promptText="mm/dd/yyyy"/>
                            </VBox>
                        </HBox>

                        <HBox spacing="10">
                            <VBox spacing="4">
                                <Label text="Credits"/>
                                <TextField fx:id="enrollCreditsField" promptText="Auto-filled or optional"/>
                            </VBox>
                            <VBox spacing="4">
                                <Label text="Course"/>
                                <ComboBox fx:id="enrollCourseBox" prefWidth="150"/>
                            </VBox>
                            <VBox spacing="4">
                                <Label text="Period"/>
                                <ComboBox fx:id="enrollPeriodBox" prefWidth="150"/>
                            </VBox>
                        </HBox>

                        <HBox spacing="10">
                            <Button text="Enroll" onAction="#handleEnroll"/>
                        </HBox>

                        <Separator/>

                        <Label text="Drop Student" style="-fx-font-weight: bold;"/>

                        <HBox spacing="10">
                            <VBox spacing="4">
                                <Label text="First Name"/>
                                <TextField fx:id="dropFirstNameField" promptText="First name"/>
                            </VBox>
                            <VBox spacing="4">
                                <Label text="Last Name"/>
                                <TextField fx:id="dropLastNameField" promptText="Last name"/>
                            </VBox>
                            <VBox spacing="4">
                                <Label text="Date of Birth"/>
                                <TextField fx:id="dropDobField" promptText="mm/dd/yyyy"/>
                            </VBox>
                        </HBox>

                        <HBox spacing="10">
                            <VBox spacing="4">
                                <Label text="Course"/>
                                <ComboBox fx:id="dropCourseBox" prefWidth="150"/>
                            </VBox>
                            <VBox spacing="4">
                                <Label text="Period"/>
                                <ComboBox fx:id="dropPeriodBox" prefWidth="150"/>
                            </VBox>
                        </HBox>

                        <HBox spacing="10">
                            <Button text="Drop" onAction="#handleDrop"/>
                        </HBox>
                    </VBox>
                </content>
            </Tab>

            <!-- SCHOLARSHIP / REPORTS -->
            <Tab text="Reports">
                <content>
                    <VBox spacing="12">
                        <padding>
                            <Insets top="12" right="12" bottom="12" left="12"/>
                        </padding>

                        <Label text="Scholarship / Reports"
                               style="-fx-font-size: 16px; -fx-font-weight: bold;"/>

                        <Label text="Update Scholarship" style="-fx-font-weight: bold;"/>

                        <HBox spacing="10">
                            <VBox spacing="4">
                                <Label text="First Name"/>
                                <TextField fx:id="scholarshipFirstNameField" promptText="First name"/>
                            </VBox>
                            <VBox spacing="4">
                                <Label text="Last Name"/>
                                <TextField fx:id="scholarshipLastNameField" promptText="Last name"/>
                            </VBox>
                            <VBox spacing="4">
                                <Label text="Date of Birth"/>
                                <TextField fx:id="scholarshipDobField" promptText="mm/dd/yyyy"/>
                            </VBox>
                        </HBox>

                        <HBox spacing="10">
                            <VBox spacing="4">
                                <Label text="Scholarship Amount"/>
                                <TextField fx:id="scholarshipField" promptText="Amount"/>
                            </VBox>
                        </HBox>

                        <HBox spacing="10">
                            <Button text="Apply Scholarship" onAction="#handleScholarshipFX"/>
                        </HBox>

                        <Separator/>

                        <HBox spacing="10">
                            <Button text="Tuition Report" onAction="#handleTuitionReportFX"/>
                            <Button text="Graduation Report" onAction="#handleGraduationReportFX"/>
                        </HBox>
                    </VBox>
                </content>
            </Tab>

        </tabs>
    </TabPane>

    <VBox spacing="4">
        <Label text="Output"
               style="-fx-font-size: 15px; -fx-font-weight: bold;"/>
        <TextArea fx:id="outputArea"
                  prefHeight="220"
                  editable="false"
                  wrapText="true"/>
    </VBox>

</VBox>

